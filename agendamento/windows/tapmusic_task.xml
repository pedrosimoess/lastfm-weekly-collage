<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler definition — runs tapmusic.py every Friday at 9:00 AM.

  BEFORE IMPORTING: open this file in a text editor and replace every
  occurrence of  C:\path\to\LastfmAutomacao  with the real path on your machine.

  IMPORT:
    1. Open Task Scheduler (search "Task Scheduler" in Start menu)
    2. Action → Import Task… → select this file
    3. Review settings and click OK

  OR via PowerShell (run as Administrator):
    Register-ScheduledTask -Xml (Get-Content tapmusic_task.xml | Out-String) `
                           -TaskName "tapmusic" -Force
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">

  <RegistrationInfo>
    <Description>Weekly Last.fm album collage generator via tapmusic.net</Description>
    <Author>tapmusic-collage</Author>
  </RegistrationInfo>

  <Triggers>
    <CalendarTrigger>
      <!-- Start date is arbitrary; the weekly recurrence is what matters -->
      <StartBoundary>2026-01-02T09:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek>
          <Friday />
        </DaysOfWeek>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>

  <Actions Context="Author">
    <Exec>
      <!-- Use "python" if it's on PATH, or the full path to python.exe -->
      <Command>python</Command>
      <Arguments>C:\path\to\LastfmAutomacao\tapmusic.py</Arguments>
      <WorkingDirectory>C:\path\to\LastfmAutomacao</WorkingDirectory>
    </Exec>
  </Actions>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT10M</ExecutionTimeLimit>
    <Enabled>true</Enabled>
  </Settings>

</Task>
